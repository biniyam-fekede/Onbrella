# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server port (default: 5001)
PORT=5001

# Hardware simulation/mock server URL (default: http://localhost:3000)
HARDWARE_URL=http://localhost:3000

# Database connection URL (REQUIRED)
# Get this from Supabase: Project Settings -- Database -- Connection string (URI)
# Use Transaction mode and replace [YOUR-PASSWORD] with your database password
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Legacy fallback (optional; keep only for backward compatibility)
# SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Admin API: JWT verification (REQUIRED for /api/admin/*)
# Both must be from the SAME Supabase project (the one your frontend uses).
# - SUPABASE_URL: Project Settings → General → Project URL (no trailing slash)
# - SUPABASE_SERVICE_ROLE_KEY: Project Settings → API → Legacy anon, service_role → service_role (secret)
# If you get 401 on /api/admin/*, the key is likely from a different project — check the dashboard URL
# (e.g. .../project/hejoglensdngmesfsdf/...) and use the service_role key from that project.
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Optional admin email override
# Admin 1 # password Admin123!

ADMIN_EMAIL=admin@onbrella.com 

#ADMin 2 # password Admin2123!
#ADMIN_EMAIL=newadmin@onbrella.com 

# Stripe API key used to create PaymentIntents

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
